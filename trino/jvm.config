# ============================================================
# jvm.config — JVM settings for Trino (local development)
#
# Mounted at /etc/trino/jvm.config inside the Trino container.
#
# These settings are tuned for a developer laptop (8–16 GB RAM).
# For production, increase Xmx and adjust GC settings based on
# the worker node profile.
# ============================================================

# ── Heap ─────────────────────────────────────────────────────
# 2 GB is comfortable for local dev with a few concurrent queries.
# Raise to 4–8 GB on machines with more available RAM.
-Xmx2G
-Xms512M

# ── Garbage collector ─────────────────────────────────────────
# G1GC is the recommended collector for Trino. It provides
# predictable pause times and handles the large heap regions
# created by Trino's memory pool allocations well.
-XX:+UseG1GC

# Reduce the maximum time a GC thread holds the JVM lock.
# Helps keep query latency predictable for interactive use.
-XX:G1HeapRegionSize=32M

# ── OOM handling ─────────────────────────────────────────────
# Kill the JVM immediately on OutOfMemoryError so that Docker
# can restart the container rather than leaving it in a broken
# half-alive state.
-XX:+ExitOnOutOfMemoryError

# Emit a heap dump on OOM for post-mortem analysis.
-XX:+HeapDumpOnOutOfMemoryError
-XX:HeapDumpPath=/var/log/trino/heapdump.hprof

# ── Trino internals ───────────────────────────────────────────
# Necessary for Trino's internal use of reflection and
# Unsafe APIs across module boundaries.
--add-opens=java.base/java.lang=ALL-UNNAMED
--add-opens=java.base/java.nio=ALL-UNNAMED
--add-opens=java.base/sun.nio.ch=ALL-UNNAMED

# ── Logging / diagnostics ─────────────────────────────────────
-Djdk.attach.allowAttachSelf=true
-Dfile.encoding=UTF-8
