# ============================================================
# health-iot-lakehouse — environment variables template
# Copy this file to .env and fill in real values before starting.
# The .env file is excluded from version control (.gitignore).
# ============================================================

# ------------------------------------------------------------
# MinIO (S3-compatible object storage)
# ------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password

# Alias used by the mc client inside the init container
MINIO_ALIAS=local

# Buckets created during init
MINIO_WAREHOUSE_BUCKET=warehouse
MINIO_RAW_BUCKET=raw

# ------------------------------------------------------------
# PostgreSQL (Iceberg catalog metadata backend)
# ------------------------------------------------------------
POSTGRES_USER=iceberg
POSTGRES_PASSWORD=change_me_iceberg_password
POSTGRES_DB=iceberg_catalog
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ------------------------------------------------------------
# Iceberg REST Catalog
# ------------------------------------------------------------
ICEBERG_REST_PORT=8181
# Warehouse root — must match the MinIO bucket name
ICEBERG_WAREHOUSE=s3://warehouse

# ------------------------------------------------------------
# Trino
# ------------------------------------------------------------
TRINO_PORT=8080
# MinIO credentials passed to Trino for S3 access
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_password

# ------------------------------------------------------------
# Apache Airflow (CeleryExecutor)
# ------------------------------------------------------------
AIRFLOW_PORT=8082
AIRFLOW__CORE__EXECUTOR=CeleryExecutor

# Generate a Fernet key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=change_me_generate_with_fernet

AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:change_me_airflow_password@postgres:5432/airflow_metadata

# Generate a random secret key: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=change_me_generate_random_secret

AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:change_me_airflow_password@postgres:5432/airflow_metadata

AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me_airflow_admin_password
AIRFLOW_ADMIN_EMAIL=admin@example.com

# PostgreSQL credentials for the Airflow metadata DB
# These are separate from the Iceberg catalog DB above
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=change_me_airflow_password
AIRFLOW_POSTGRES_DB=airflow_metadata

# ------------------------------------------------------------
# OpenMetadata (docker-compose.openmetadata.yml)
# ------------------------------------------------------------
OM_MYSQL_ROOT_PASSWORD=change_me_om_mysql_password
OM_MYSQL_USER=openmetadata_user
OM_MYSQL_PASSWORD=change_me_om_mysql_password
OM_MYSQL_DATABASE=openmetadata_db
